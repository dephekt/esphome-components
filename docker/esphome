#!/usr/bin/env bash
# ESPHome CLI in the local-context dev container, against this repo.
#
# This repository owns reusable components only. Real grow controller firmware
# configs live in stackdrift/grow-fleet.
#
# The user's default docker context may point at a remote host. Force the local
# daemon so scratch configs and component examples can still use local USB,
# mDNS, and OTA access when needed. Run from anywhere:
#
#   ./docker/esphome config  path/to/example.yaml
#   ./docker/esphome compile path/to/scratch.yaml
#   ./docker/esphome run     path/to/scratch.yaml --device /dev/ttyACM0
#
# Config paths are relative to the repo root (mounted at /config in the
# container). esptool/other tools: ./docker/esphome ... or override the
# entrypoint with raw `docker compose` if needed.
set -euo pipefail
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec env DOCKER_CONTEXT=default docker compose -f "$here/esphome-dev.yml" run --rm esphome "$@"
